{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devprod.local/schemas/postmortem-response.schema.json",
  "type": "object",
  "required": ["run", "postmortem"],
  "properties": {
    "run": {
      "type": "object",
      "required": [
        "id",
        "incidentId",
        "incidentTitle",
        "providerMode",
        "evaluationScore",
        "rootCause",
        "createdAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "incidentId": { "type": "string" },
        "incidentTitle": { "type": "string" },
        "providerMode": { "enum": ["demo", "live"] },
        "evaluationScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "rootCause": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "postmortem": {
      "type": "object",
      "required": ["title", "impact", "rootCause", "followUps"],
      "properties": {
        "title": { "type": "string" },
        "impact": { "type": "string" },
        "rootCause": { "type": "string" },
        "followUps": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
