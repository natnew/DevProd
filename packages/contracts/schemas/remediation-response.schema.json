{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://devprod.local/schemas/remediation-response.schema.json",
  "type": "object",
  "required": ["run", "remediation"],
  "properties": {
    "run": {
      "type": "object",
      "required": [
        "id",
        "incidentId",
        "incidentTitle",
        "providerMode",
        "evaluationScore",
        "rootCause",
        "createdAt"
      ],
      "properties": {
        "id": { "type": "string" },
        "incidentId": { "type": "string" },
        "incidentTitle": { "type": "string" },
        "providerMode": { "enum": ["demo", "live"] },
        "evaluationScore": { "type": "number", "minimum": 0, "maximum": 100 },
        "rootCause": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "remediation": {
      "type": "object",
      "required": ["immediateActions", "followUpActions", "risks", "requiresReview"],
      "properties": {
        "immediateActions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "action", "owner", "priority"],
            "properties": {
              "id": { "type": "string" },
              "action": { "type": "string" },
              "owner": { "type": "string" },
              "priority": { "enum": ["immediate", "next", "follow-up"] }
            },
            "additionalProperties": false
          }
        },
        "followUpActions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "action", "owner", "priority"],
            "properties": {
              "id": { "type": "string" },
              "action": { "type": "string" },
              "owner": { "type": "string" },
              "priority": { "enum": ["immediate", "next", "follow-up"] }
            },
            "additionalProperties": false
          }
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requiresReview": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
